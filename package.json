{
  "name": "nhsuk-prototype-kit",
  "version": "7.0.1",
  "description": "Rapidly create HTML prototypes of NHS websites and services.",
  "main": "app.js",
  "scripts": {
    "map:build": "node map/build.js",
    "map:watch": "node --watch-preserve-output --watch-path=map/journeys --watch-path=map/templates --watch-path=map/assets --watch-path=map/build.js --watch-path=map/router.js map/build.js",
    "docs:variants:capture": "node scripts/capture-doc-variants.js",
    "docs:variants:validate": "node scripts/validate-doc-variants.js",
    "prestart": "npm run map:build",
    "start": "node scripts/start-dev.js",
    "start:app": "node app.js",
    "watch": "node --watch app.js"
  },
  "author": "https://github.com/nhsuk/",
  "license": "MIT",
  "dependencies": {
    "dotenv": "^17.2.2",
    "js-yaml": "^4.2.0",
    "luxon": "^3.7.2",
    "markdown-it": "^14.2.0",
    "nhsuk-frontend": "^10.2.2",
    "nhsuk-prototype-kit": "8.0.0-beta.7",
    "nunjucks": "^3.2.4"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^8.42.0",
    "@typescript-eslint/parser": "^8.43.0",
    "eslint": "^8.57.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-config-standard": "^17.1.0",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-jest": "^29.0.1",
    "eslint-plugin-jest-dom": "^5.5.0",
    "eslint-plugin-jsdoc": "^54.3.1",
    "eslint-plugin-n": "^16.6.2",
    "eslint-plugin-promise": "^6.6.0",
    "jest": "^30.1.3",
    "prettier": "^3.6.2"
  },
  "engines": {
    "node": "^20.9.0 || ^22.11.0"
  }
}
